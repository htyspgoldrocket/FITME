# 환경 변수 — API 키는 절대 커밋 금지 (규칙 10)
.env
.env.*
server/.env

# 의존성
node_modules/
server/__pycache__/
**/__pycache__/
server/venv/
.venv/
.pytest_cache/

# 빌드 산출물
dist/
dist-ssr/
*.local

# 에디터/OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# 테스트 픽스처 — 개인 신체 사진·실측값은 로컬에만 보관 (README.md만 커밋)
server/tests/fixtures/*
